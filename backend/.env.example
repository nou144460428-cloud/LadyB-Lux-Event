# Database (local Postgres default from docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ladyb_lux_event
# Optional alternative to adapter mode:
# PRISMA_ACCELERATE_URL=prisma://accelerate.prisma-data.net/?api_key=your_api_key

# JWT
JWT_SECRET=50399f636085156560f5ad62b95fcfb1ac65ce2f8d26ad19c282fe9032ddded6
ADMIN_REGISTRATION_SECRET=change-this-admin-secret
ADMIN_BOOTSTRAP_SECRET=change-this-bootstrap-secret

# Monitoring (optional)
SENTRY_DSN=

# Paystack Payment Gateway (E1)
PAYSTACK_SECRET=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# Monnify Payment Gateway (optional)
# Use sandbox for development: https://sandbox.monnify.com
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=your_monnify_api_key
MONNIFY_SECRET_KEY=your_monnify_secret_key
MONNIFY_CONTRACT_CODE=your_monnify_contract_code
MONNIFY_WEBHOOK_SECRET=your_monnify_webhook_secret

# Frontend URL for payment redirects
FRONTEND_URL=http://localhost:3000

# WhatsApp Business API
WHATSAPP_API_BASE=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_business_access_token

# Server Port
PORT=3001
NODE_ENV=development

# Basic API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
